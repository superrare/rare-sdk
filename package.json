{
  "name": "@rareprotocol/rare-sdk",
  "version": "0.1.0",
  "description": "SuperRare / Rare Protocol TypeScript SDK: marketplace, minting, auctions, offers, releases, and the Rare API client",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/superrare/rare-sdk.git"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/sdk/index.d.ts",
        "default": "./dist/sdk/index.js"
      },
      "require": {
        "types": "./dist/sdk/index.d.cts",
        "default": "./dist/sdk/index.cjs"
      }
    },
    "./client": {
      "import": {
        "types": "./dist/sdk/index.d.ts",
        "default": "./dist/sdk/index.js"
      },
      "require": {
        "types": "./dist/sdk/index.d.cts",
        "default": "./dist/sdk/index.cjs"
      }
    },
    "./contracts": {
      "import": {
        "types": "./dist/sdk/contracts.d.ts",
        "default": "./dist/sdk/contracts.js"
      },
      "require": {
        "types": "./dist/sdk/contracts.d.cts",
        "default": "./dist/sdk/contracts.cjs"
      }
    },
    "./utils": {
      "import": {
        "types": "./dist/sdk/public-utils.d.ts",
        "default": "./dist/sdk/public-utils.js"
      },
      "require": {
        "types": "./dist/sdk/public-utils.d.cts",
        "default": "./dist/sdk/public-utils.cjs"
      }
    },
    "./data-access": {
      "import": {
        "types": "./dist/data-access/index.d.ts",
        "default": "./dist/data-access/index.js"
      },
      "require": {
        "types": "./dist/data-access/index.d.cts",
        "default": "./dist/data-access/index.cjs"
      }
    },
    "./contracts/*": {
      "import": {
        "types": "./dist/contracts/*.d.ts",
        "default": "./dist/contracts/*.js"
      },
      "require": {
        "types": "./dist/contracts/*.d.cts",
        "default": "./dist/contracts/*.cjs"
      }
    },
    "./data-access/*": {
      "import": {
        "types": "./dist/data-access/*.d.ts",
        "default": "./dist/data-access/*.js"
      },
      "require": {
        "types": "./dist/data-access/*.d.cts",
        "default": "./dist/data-access/*.cjs"
      }
    },
    "./liquid/*": {
      "import": {
        "types": "./dist/liquid/*.d.ts",
        "default": "./dist/liquid/*.js"
      },
      "require": {
        "types": "./dist/liquid/*.d.cts",
        "default": "./dist/liquid/*.cjs"
      }
    },
    "./swap/*": {
      "import": {
        "types": "./dist/swap/*.d.ts",
        "default": "./dist/swap/*.js"
      },
      "require": {
        "types": "./dist/swap/*.d.cts",
        "default": "./dist/swap/*.cjs"
      }
    },
    "./*": {
      "import": {
        "types": "./dist/sdk/*.d.ts",
        "default": "./dist/sdk/*.js"
      },
      "require": {
        "types": "./dist/sdk/*.d.cts",
        "default": "./dist/sdk/*.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "generate:types": "openapi-typescript https://api.superrare.com/doc -o src/data-access/schema.d.ts",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run test",
    "lint": "eslint src test",
    "test": "npm run build && vitest run"
  },
  "dependencies": {
    "merkletreejs": "0.6.0",
    "openapi-fetch": "0.17.0",
    "viem": "2.48.8"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.6.0",
    "eslint": "10.3.0",
    "eslint-plugin-functional": "^9.0.4",
    "globals": "17.6.0",
    "openapi-typescript": "7.13.0",
    "tsdown": "^0.22.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.2",
    "vitest": "4.1.5"
  },
  "main": "./dist/sdk/index.cjs",
  "module": "./dist/sdk/index.js",
  "types": "./dist/sdk/index.d.cts",
  "engines": {
    "node": ">=20.19.0"
  },
  "sideEffects": false,
  "typesVersions": {
    "*": {
      "client": [
        "./dist/sdk/index.d.ts"
      ],
      "contracts": [
        "./dist/sdk/contracts.d.ts"
      ],
      "utils": [
        "./dist/sdk/public-utils.d.ts"
      ],
      "data-access": [
        "./dist/data-access/index.d.ts"
      ],
      "contracts/*": [
        "./dist/contracts/*"
      ],
      "data-access/*": [
        "./dist/data-access/*"
      ],
      "liquid/*": [
        "./dist/liquid/*"
      ],
      "swap/*": [
        "./dist/swap/*"
      ]
    }
  }
}
