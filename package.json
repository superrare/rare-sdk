{
  "name": "@rareprotocol/rare-sdk",
  "version": "0.1.0",
  "description": "SuperRare / Rare Protocol TypeScript SDK: marketplace, minting, auctions, offers, releases, and the Rare API client",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/superrare/rare-sdk"
  },
  "exports": {
    ".": {
      "import": "./dist/sdk/index.js",
      "types": "./dist/sdk/index.d.ts"
    },
    "./client": {
      "import": "./dist/sdk/index.js",
      "types": "./dist/sdk/index.d.ts"
    },
    "./contracts": {
      "import": "./dist/sdk/contracts.js",
      "types": "./dist/sdk/contracts.d.ts"
    },
    "./utils": {
      "import": "./dist/sdk/public-utils.js",
      "types": "./dist/sdk/public-utils.d.ts"
    },
    "./contracts/*": {
      "import": "./dist/contracts/*",
      "types": "./dist/contracts/*"
    },
    "./data-access": {
      "import": "./dist/data-access/index.js",
      "types": "./dist/data-access/index.d.ts"
    },
    "./data-access/*": {
      "import": "./dist/data-access/*",
      "types": "./dist/data-access/*"
    },
    "./liquid/*": {
      "import": "./dist/liquid/*",
      "types": "./dist/liquid/*"
    },
    "./swap/*": {
      "import": "./dist/swap/*",
      "types": "./dist/swap/*"
    },
    "./*": {
      "import": "./dist/sdk/*",
      "types": "./dist/sdk/*"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json && cp src/data-access/schema.d.ts dist/data-access/schema.d.ts",
    "typecheck": "tsc --noEmit",
    "generate:types": "openapi-typescript https://api.superrare.com/doc -o src/data-access/schema.d.ts",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "merkletreejs": "0.6.0",
    "openapi-fetch": "0.17.0",
    "viem": "2.48.8"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "openapi-typescript": "7.13.0",
    "typescript": "5.9.3"
  }
}
